#!/usr/bin/env bash
# Enforce Conventional Commits message format.
#
# Enable for this clone (one-time):
#     git config core.hooksPath .githooks
#
# Bypass for a single commit (rare, justify it):
#     git commit --no-verify ...

set -eu

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

# Pass-through for non-authored commit kinds
case "$first_line" in
    "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*)
        exit 0
        ;;
esac

# <type>(optional-scope)?!?: <subject>
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_./-]+\))?!?: .+'

if ! printf '%s' "$first_line" | grep -qE "$pattern"; then
    cat >&2 <<EOF
✗ Commit message does not follow Conventional Commits.

  Expected:  <type>[(scope)][!]: <subject>
  Got:       $first_line

  Allowed types: feat fix docs style refactor perf test build ci chore revert
  Examples:
    feat: add tab completion for /apiary
    fix(listener): null-guard hand item before display name lookup
    chore(deps): bump paper-api to 1.21.5
    ci: ignore paper-api in Dependabot updates

  Bypass (rare):
    git commit --no-verify ...
EOF
    exit 1
fi

# Soft-warn on long subjects (don't block)
subj_len=${#first_line}
if [ "$subj_len" -gt 72 ]; then
    echo "⚠ Subject is $subj_len chars (>72 recommended)." >&2
fi

exit 0
